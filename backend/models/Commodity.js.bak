// UPDATE the CommoditySchema to include:

const mongoose = require("mongoose");  // ← ADD THIS LINE

const PriceHistorySchema = new mongoose.Schema({
  date: { type: Date, required: true },
  price: { type: Number, required: true },
});
////////-----//////

const CommoditySchema = new mongoose.Schema(
  {
    name: { type: String, required: true },
    category: { type: String }, 
    unit: { type: String }, 
    currentPrice: { type: Number },
    priceHistory: [PriceHistorySchema],
    
    // ========== ADD THESE NEW FIELDS ==========
    // Supply Risk Indicators
    priceVolatility: { 
      type: Number, 
      description: "Historical price volatility (%)" 
    },
    supplyConcentration: { 
      type: Number, 
      min: 0, 
      max: 1,
      description: "HHI Index (Herfindahl-Hirschman Index)" 
    },
    supplyShockRisk: { 
      type: Number, 
      min: 0, 
      max: 100,
      description: "Geopolitical/supply shock risk score" 
    },
    
    // Market Risk Indicators
    demandVolatility: { 
      type: Number, 
      description: "Historical demand volatility (%)" 
    },
    marketLiquidityRisk: { 
      type: Number, 
      min: 0, 
      max: 100,
      description: "Market liquidity risk (0=high liquidity, 100=illiquid)" 
    },
    
    // Structural Risk Indicators
    productionCapacityGap: { 
      type: Number, 
      description: "Avg production capacity gap (%)" 
    },
    tradeDependencyRatio: { 
      type: Number, 
      min: 0, 
      max: 100,
      description: "Trade dependency as % of global consumption" 
    },
    
    // Verification
    verified: { type: Boolean, default: false },
    source: { type: String }, // "official_api", "manual_input", etc.
    lastUpdated: { type: Date, default: Date.now },
    // ========== END NEW FIELDS ==========
  },
  { timestamps: true },
);

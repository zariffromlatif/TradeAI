# Copy to .env and fill in. Never commit .env.

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/tradeai?retryWrites=true&w=majority

JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=1d
JWT_REMEMBER_EXPIRES_IN=14d

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# true = allow POST /api/payment/demo-upgrade (no Stripe). Use only for local demos; never in production.
DEMO_PAYMENT=false

# Secret code required to register as admin. Share only with trusted admins.
ADMIN_INVITE_CODE=replace-with-secure-code

# Comma-separated frontend origins for CORS (empty allows all; set this in production).
CORS_ORIGINS=http://localhost:5173

# Public frontend URL for Stripe Checkout return URLs (fallback: first CORS origin).
FRONTEND_PUBLIC_URL=http://localhost:5173

# Stripe Checkout line-item amounts (USD cents) for Gold / Diamond plans.
STRIPE_GOLD_AMOUNT_CENTS=2999
STRIPE_DIAMOND_AMOUNT_CENTS=7999

# Redis connection (required for Bull async report queue and realtime workloads).
REDIS_URL=redis://127.0.0.1:6379

# Report retention/cleanup settings.
REPORT_RETENTION_DAYS=30
REPORT_CLEANUP_INTERVAL_MINUTES=60

# Free trade sync settings used by scripts/syncTradeFlows.js
# Uses World Bank indicators (no API key needed).
# ISO2 reporters to sync (comma-separated). Example: BD,US,IN,CN,DE
TRADE_SYNC_COUNTRY_CODES=BD,US,IN,CN,DE

# Years of annual national totals to ingest (reporter vs World).
TRADE_SYNC_YEAR_SPAN=12

# Optional: enable commodity-level sync from UN Comtrade (annual, reporter vs World).
TRADE_SYNC_COMTRADE_ENABLE=false

# Optional API key for UN Comtrade (depends on your plan/limits).
COMTRADE_API_KEY=

# Comma-separated HS codes to ingest for country+commodity comparisons.
# Example: crude oil (2709), wheat (1001), rice (1006), gold (7108)
TRADE_SYNC_COMTRADE_HS_CODES=2709,1001,1006,7108

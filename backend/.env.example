# Copy to .env and fill in. Never commit .env.

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/tradeai?retryWrites=true&w=majority

JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=1d
JWT_REMEMBER_EXPIRES_IN=14d

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# true = allow POST /api/payment/demo-upgrade (no Stripe). Use only for local demos; never in production.
DEMO_PAYMENT=false

# Secret code required to register as admin. Share only with trusted admins.
ADMIN_INVITE_CODE=replace-with-secure-code

# Comma-separated frontend origins for CORS (empty allows all; set this in production).
CORS_ORIGINS=http://localhost:5173

# Free trade sync settings used by scripts/syncTradeFlows.js
# Uses World Bank indicators (no API key needed).
# ISO2 reporters to sync (comma-separated). Example: BD,US,IN,CN,DE
TRADE_SYNC_COUNTRY_CODES=BD,US,IN,CN,DE

# Years of annual national totals to ingest (reporter vs World).
TRADE_SYNC_YEAR_SPAN=12
